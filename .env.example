DEFAULT_FROM_EMAIL=sebasborrego1@gmail.com

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,TU_IP_PUBLICA_OCI

# Producción OCI: servir imágenes subidas (sin Nginx)
SERVE_MEDIA=True
DEBUG=False
