EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Gmail: usa tu correo y una "Contraseña de aplicación" (no la contraseña normal)
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=sebasborrego1@gmail.com
